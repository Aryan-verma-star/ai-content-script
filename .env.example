# YouTube Data API v3 key — obtain from Google Cloud Console
YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here

# LLM Provider — set to either 'openai' or 'anthropic'
LLM_PROVIDER=openai

# OpenAI API key (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API key (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Target niche for trend scraping (e.g. 'personal finance', 'fitness', 'AI tools')
TARGET_NICHE=personal finance

# Maximum number of transcript characters to send to LLM (controls token cost)
MAX_TRANSCRIPT_CHARS=1500